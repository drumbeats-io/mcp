{
	"$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
	"files": {
		"ignoreUnknown": true,
		"includes": ["**/*.ts", "**/*.js", "**/*.json"]
	},
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"linter": {
		"rules": {
			"preset": "recommended",
			"style": {
				"useConst": "error",
				"noUnusedTemplateLiteral": "error",
				"noNonNullAssertion": "off"
			},
			"correctness": {},
			"suspicious": {
				"noThenProperty": "off"
			},
			"performance": {},
			"security": {},
			"nursery": {},
			"complexity": {}
		}
	},
	"javascript": {
		"formatter": {
			"indentStyle": "space",
			"indentWidth": 2,
			"lineWidth": 120,
			"quoteStyle": "single",
			"semicolons": "asNeeded",
			"trailingCommas": "es5"
		}
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
